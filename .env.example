# NewsAPI.org key - get from https://newsapi.org/register (free tier: 100 req/day)
NEWSAPI_KEY=

# OpenAI API key - get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gmail address used to send emails
GMAIL_ADDRESS=

# Gmail App Password (NOT your regular password)
# Enable 2-Step Verification, then generate at: Google Account > Security > App passwords
GMAIL_APP_PASSWORD=

# Optional: recipient email (defaults to GMAIL_ADDRESS if not set)
EMAIL_RECIPIENT=
